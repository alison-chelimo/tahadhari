# Postgres connection string (existing requirement, see app/database.py) - not new to ai_layer
DATABASE_URL=postgresql://user:pass@localhost:5432/tahadhari

# --- app auth settings (see app/auth.py) ---

# Shared secret machine callers (ai_layer, the weather/KMD ingest feed) send as the
# X-API-Key header. Must match TAHADHARI_SERVICE_API_KEY below -- same secret, two names,
# since it means something different on each side of the API boundary.
SERVICE_API_KEY=change-me-to-a-random-secret

# Signing secret/algorithm/expiry for admin JWTs issued by POST /auth/login.
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Credentials for seed_admin.py, which bootstraps the one admin account. Not read at
# request time -- only by that one-off script.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# --- ai_layer settings ---

# The ai_layer-side name for the same secret as SERVICE_API_KEY above -- must match it.
TAHADHARI_SERVICE_API_KEY=change-me-to-a-random-secret

# Claude is currently disabled in favor of OpenAI -- switch back by uncommenting these
# and see ai_layer/clients/claude_client.py (kept intact, not deleted).
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-5
# CLAUDE_TIMEOUT_SECONDS=30.0
# CLAUDE_MAX_RETRIES=2

# OpenAI API key. Required for real ChatGPT calls (personalizer's grammar pass,
# flood-warning generation, feedback classification). Not needed to run the unit
# tests, which mock the OpenAI client entirely.
OPENAI_API_KEY=sk-...

# OpenAI model used for both the personalizer's grammar/phrasing pass and the
# feedback classifier. Change here, not in code, if it needs to move to a newer model.
OPENAI_MODEL=gpt-4o-mini

# Timeout (seconds) and retry count for calls to the OpenAI API
OPENAI_TIMEOUT_SECONDS=30.0
OPENAI_MAX_RETRIES=2

# Base URL of Alison's Tahadhari FastAPI backend (run via `uvicorn app.main:app --reload`)
TAHADHARI_API_BASE_URL=http://localhost:8000

# Timeout (seconds) and retry count for calls to the Tahadhari API
# (/alerts, /templates, /alerts/predict, /messages, /feedback)
TAHADHARI_API_TIMEOUT_SECONDS=5.0
TAHADHARI_API_MAX_RETRIES=3

# --- ICPAC (geoportal.icpac.net) WFS polling, see ai_layer/icpac_poll.py ---
# No layer on ICPAC's public GeoNode portal is a true live rainfall-alert feed as of
# writing. The defaults below point at geonode:gha_dr_events, a historical drought-event
# layer confirmed reachable over WFS, so the poller runs end-to-end out of the box.
# Swap ICPAC_LAYER_TYPE_NAME/ICPAC_GEOGRAPHY_REF_FIELD/ICPAC_RAINFALL_FIELD once ICPAC
# publishes a real live hazard layer -- browse available layers/fields at
# https://geoportal.icpac.net/api/layers/ and https://geoportal.icpac.net/developer/.
ICPAC_BASE_URL=https://geoportal.icpac.net
ICPAC_LAYER_TYPE_NAME=geonode:gha_dr_events
ICPAC_GEOGRAPHY_TYPE=corridor
ICPAC_GEOGRAPHY_REF_FIELD=iso3
ICPAC_RAINFALL_FIELD=duration
ICPAC_TIMEOUT_SECONDS=10.0
ICPAC_MAX_RETRIES=3
ICPAC_POLL_INTERVAL_SECONDS=3600.0

# --- Open-Meteo (open-meteo.com), see ai_layer/clients/open_meteo_client.py ---
# Free, no-API-key REST weather API queried per lat/lon coordinate. Used by the
# location/weather conversation flow (ai_layer/location_poll.py), not the ICPAC poller.
OPEN_METEO_BASE_URL=https://api.open-meteo.com
OPEN_METEO_TIMEOUT_SECONDS=10.0
OPEN_METEO_MAX_RETRIES=3

# --- Google Maps Geocoding API, see ai_layer/clients/google_maps_client.py ---
# Resolves a user's free-text location reply (e.g. "Kitengela") to lat/lon before it's
# handed to Open-Meteo. Get a key at https://console.cloud.google.com/google/maps-apis.
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_BASE_URL=https://maps.googleapis.com
GOOGLE_MAPS_TIMEOUT_SECONDS=10.0
GOOGLE_MAPS_MAX_RETRIES=3

# Interval for ai_layer/location_poll.py -- much shorter than ICPAC_POLL_INTERVAL_SECONDS
# since this is a per-user, near-real-time reply rather than a scheduled bulk sweep.
LOCATION_POLL_INTERVAL_SECONDS=300.0

# Local dead-letter file for /messages and /feedback POSTs that fail after retries
# are exhausted (JSONL - one failed record per line; see ai_layer/dead_letter.py)
DEAD_LETTER_PATH=ai_layer_dead_letter.jsonl
